{
  "carlquant_getting_started": {
    "layout": "comprehensive_guide",
    "title": {
      "text": "◆ CARL QUANT - GETTING STARTED",
      "color": "header_workflow"
    },
    "workflow_steps": [
      {
        "number": "1️⃣",
        "title": "Load Images",
        "panel": "Left Panel",
        "actions": [
          "▸ Click 'Select Folder' button",
          "▸ Choose directory with OCT image stacks",
          "▸ Each subfolder = one specimen"
        ]
      },
      {
        "number": "2️⃣",
        "title": "Review Specimens",
        "panel": "Specimen Table",
        "actions": [
          "▸ View loaded specimens in table",
          "▸ Click specimen to select",
          "▸ Check slice count and status"
        ]
      },
      {
        "number": "3️⃣",
        "title": "Define Regions",
        "panel": "Image Viewer",
        "actions": [
          "▸ REGION: Click twice for vertical boundaries",
          "▸ AIR: Click & drag for rectangle",
          "▸ First definition applies to ALL slices"
        ]
      },
      {
        "number": "4️⃣",
        "title": "Configure Settings",
        "panel": "Settings Panel",
        "actions": [
          "▸ Set operator name & measurement #",
          "▸ Configure region parameters",
          "▸ Adjust analysis settings"
        ]
      },
      {
        "number": "5️⃣",
        "title": "Start Analysis",
        "panel": "Left Panel",
        "actions": [
          "▸ Click 'Start Analyzing' button",
          "▸ Results saved to Data_[operator]_[measurement]",
          "▸ Configuration auto-saved"
        ]
      }
    ],
    "quick_tips": {
      "header": "💡 QUICK TIPS",
      "tips": [
        "◄ ► Navigate slices",
        "⊕ Ctrl+Wheel: Zoom in/out",
        "✋ Ctrl+Drag: Pan image",
        "⌨ H key: Toggle overlays",
        "▬ Yellow lines = Regions",
        "▭ Cyan box = AIR"
      ]
    },
    "panel_guide": {
      "header": "📍 PANEL LOCATIONS",
      "panels": [
        {"name": "▸ Load/Analyze", "location": "Left side"},
        {"name": "▸ Specimen Table", "location": "Bottom left"},
        {"name": "▸ Image Viewer", "location": "Center/Right"},
        {"name": "▸ Settings", "location": "Right side"}
      ]
    }
  },
